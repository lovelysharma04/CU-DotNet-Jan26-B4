@model SmartBank.WebService.DTOs.DepositWithdrawDTO

@{
    ViewData["Title"] = "Withdraw";
}

<h2>Withdraw</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<form asp-action="Withdraw" method="post">
    @Html.AntiForgeryToken()

    <!-- 🔥 REQUIRED -->
    <input type="hidden" asp-for="AccountId" />

    <div class="mb-3">
        <label asp-for="Amount" class="form-label"></label>
        <input asp-for="Amount" type="number" step="0.01" class="form-control" />
        <span asp-validation-for="Amount" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-danger">Withdraw</button>

    <a asp-controller="Account" asp-action="Index" class="btn btn-secondary">
        Back to Accounts
    </a>
</form>