@model List<Laptop>

<h2>Laptop Inventory</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

<a asp-action="Create" class="btn btn-success mb-3">Add New Laptop</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Model</th>
            <th>Serial</th>
            <th>Price</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var laptop in Model)
        {
            <tr>
                <td>@laptop.ModelName</td>
                <td>@laptop.SerialNumber</td>
                <td>@laptop.Price</td>
            </tr>
        }
    </tbody>
</table>