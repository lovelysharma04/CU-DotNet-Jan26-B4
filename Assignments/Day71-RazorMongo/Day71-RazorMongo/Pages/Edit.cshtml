@page "{id}"
@model EditModel

<div class="container mt-5">
    <div class="card p-4 shadow">
        <h3 class="text-warning text-center">✏️ Edit Laptop</h3>

        <form method="post">
            <input type="hidden" asp-for="Laptop.Id" />

            <div class="mb-3">
                <label>Model Name</label>
                <input asp-for="Laptop.ModelName" class="form-control" />
            </div>

            <div class="mb-3">
                <label>Serial Number</label>
                <input asp-for="Laptop.SerialNumber" class="form-control" />
            </div>

            <div class="mb-3">
                <label>Price</label>
                <input asp-for="Laptop.Price" class="form-control" />
            </div>

            <button class="btn btn-warning w-100">Update</button>
        </form>
    </div>
</div>