@model IEnumerable<Destination>

<style>
    body {
        background: url('/images/travel-bg.jpg') no-repeat center center fixed;
        background-size: cover;
    }

    .main-container {
        min-height: 100vh;
        padding: 40px 20px;
        background: rgba(0, 0, 0, 0.5);
        backdrop-filter: blur(6px); /* ✨ Glass effect */
    }

    h2 {
        color: white;
        font-weight: bold;
    }

    .card {
        border-radius: 15px;
        background: rgba(255, 255, 255, 0.9);
        transition: 0.3s;
    }

        .card:hover {
            transform: scale(1.03);
        }

    .btn {
        border-radius: 20px;
    }
</style>

<div class="main-container">

    <h2 class="text-center mb-4">🌍 Travel Destinations</h2>

    <div class="text-end mb-3">
        <a asp-action="Create" class="btn btn-success">➕ Add Destination</a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-light text-center">
            No destinations found ✈️
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card shadow h-100 p-3">

                        <h5 class="text-primary">@item.CityName</h5>
                        <h6 class="text-muted">@item.Country</h6>

                        <p>
                            @(string.IsNullOrEmpty(item.Description)
                                ? "No description available"
                                : item.Description)
                        </p>

                        <p>⭐ @item.Rating / 5</p>

                        <small class="text-muted">
                            Last Visited: @item.LastVisited.ToShortDateString()
                        </small>

                        <div class="mt-3 text-end">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-primary">View</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                        </div>

                    </div>
                </div>
            }
        </div>
    }

</div>

