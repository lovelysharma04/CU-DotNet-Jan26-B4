@model Destination

<h2>Edit</h2>

<form asp-action="Edit">
    <input type="hidden" asp-for="Id" />

    <input asp-for="CityName" class="form-control mb-2" />
    <input asp-for="Country" class="form-control mb-2" />
    <input asp-for="Description" class="form-control mb-2" />
    <input asp-for="Rating" class="form-control mb-2" />
    <input asp-for="LastVisited" type="date" class="form-control mb-2" />

    <button class="btn btn-warning">Update</button>
</form>