
@{
    ViewData["Title"] = "showList";
}

@model List<CorporatePulsePortal.Models.Emp>

@{
    ViewData["Title"] = "Corporate Pulse Dashboard";
}

<div class="container mt-4">

    <h2>@ViewData["DepartmentName"]</h2>

    <div class="alert alert-warning">
        @ViewBag.Announcement
    </div>

    <!-- Conditional Server Status using ViewData -->
    @if ((bool)ViewData["ServerStatus"])
    {
        <div class="alert alert-success">
            Department Status: Active
        </div>
    }
    else
    {
        <div class="alert alert-danger">
            Department Status: Under Maintenance
        </div>
    }

    <h3 class="mt-4">Employee Data</h3>

    <!-- Bootstrap Table -->
    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Position</th>
                <th>Salary</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var emp in Model)
            {
                <tr>
                    <td>@emp.EmpId</td>
                    <td>@emp.Name</td>
                    <td>@emp.Position</td>
                    <td>@emp.Salary</td>
                </tr>
            }
        </tbody>

    </table>

</div>

