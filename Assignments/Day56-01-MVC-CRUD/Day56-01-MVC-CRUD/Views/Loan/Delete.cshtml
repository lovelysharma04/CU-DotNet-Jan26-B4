@model Day56_01_MVC_CRUD.Models.Loan

@{
    ViewData["Title"] = "Delete";
}

<div class="confirm-wrapper">
    <div class="card shadow-sm confirm-card">
        <div class="card-header">
            <h3 class="card-title mb-0">Confirm Delete</h3>
        </div>
        <div class="card-body">
            <p class="text-danger">Are you sure you want to delete this loan?</p>
            <hr />
            <h5>Loan</h5>
            <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Id)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Id)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.BorrowerName)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.BorrowerName)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.LenderName)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.LenderName)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Amount)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Amount)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.IsSettled)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.IsSettled)
        </dd>
    </dl>
    
            <div class="mt-3">
                <form asp-action="Delete" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger">Delete</button>
                </form>
                <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
            </div>
        </div>
    </div>
</div>
