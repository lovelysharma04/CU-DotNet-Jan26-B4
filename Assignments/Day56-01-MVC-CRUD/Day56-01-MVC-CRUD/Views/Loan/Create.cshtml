@model Day56_01_MVC_CRUD.Models.Loan

@{
    ViewData["Title"] = "Create";
}

<div class="card shadow-sm create-card">
    <div class="card-body">
        <h3 class="card-title text-primary">Create Loan</h3>
        <hr />
        <div class="row">
            <div class="col-md-6">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                    <div class="mb-3 input-group">
                        <span class="input-group-text hd">👤</span>
                        <input asp-for="BorrowerName" class="form-control" placeholder="Borrower name" />
                    </div>
                    <span asp-validation-for="BorrowerName" class="text-danger"></span>

                    <div class="mb-3 input-group">
                        <span class="input-group-text hd">🏦</span>
                        <input asp-for="LenderName" class="form-control" placeholder="Lender name" />
                    </div>
                    <span asp-validation-for="LenderName" class="text-danger"></span>

                    <div class="mb-3 input-group">
                        <span class="input-group-text hd">💰</span>
                        <input asp-for="Amount" class="form-control" placeholder="Amount" />
                    </div>
                    <span asp-validation-for="Amount" class="text-danger"></span>
                    <div class="form-check mb-3">
                        <input class="form-check-input" asp-for="IsSettled" />
                        <label class="form-check-label" asp-for="IsSettled"></label>
                    </div>
                    <div>
                        <button type="submit" class="btn btn-primary">Create</button>
                        <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
