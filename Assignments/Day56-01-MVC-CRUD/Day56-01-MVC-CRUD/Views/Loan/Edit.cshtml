@model Day56_01_MVC_CRUD.Models.Loan

@{
    ViewData["Title"] = "Edit";
}

<div class="card shadow-sm">
    <div class="card-body">
        <h3 class="card-title">Edit Loan</h3>
        <hr />
        <div class="row">
            <div class="col-md-6">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                    <div class="mb-3">
                        <label asp-for="Id" class="form-label"></label>
                        <input asp-for="Id" class="form-control" readonly />
                        <span asp-validation-for="Id" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="BorrowerName" class="form-label"></label>
                        <input asp-for="BorrowerName" class="form-control" />
                        <span asp-validation-for="BorrowerName" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="LenderName" class="form-label"></label>
                        <input asp-for="LenderName" class="form-control" />
                        <span asp-validation-for="LenderName" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Amount" class="form-label"></label>
                        <input asp-for="Amount" class="form-control" />
                        <span asp-validation-for="Amount" class="text-danger"></span>
                    </div>
                    <div class="form-check mb-3">
                        <input class="form-check-input" asp-for="IsSettled" />
                        <label class="form-check-label" asp-for="IsSettled"></label>
                    </div>
                    <div>
                        <button type="submit" class="btn btn-primary">Save</button>
                        <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
