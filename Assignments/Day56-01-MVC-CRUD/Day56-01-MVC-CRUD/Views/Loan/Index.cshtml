@model IEnumerable<Day56_01_MVC_CRUD.Models.Loan>

@{
    ViewData["Title"] = "Loans";
}

<div class="card mb-4 shadow-sm">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h3 class="mb-0">Loan List</h3>
            <div>
                <a asp-action="Create" class="btn btn-primary">Add Loan</a>
            </div>

@if (ViewData["NoResultsMessage"] != null)
{
    <div class="custom-toast-wrap">
        <div class="toast custom-toast align-items-center bg-primary text-white border-0 show" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body">
                    @ViewData["NoResultsMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>

    @section Scripts {
        <script>
            (function () {
                var toastElList = [].slice.call(document.querySelectorAll('.custom-toast'))
                toastElList.forEach(function (toastEl) {
                    var toast = new bootstrap.Toast(toastEl, { delay: 3500 })
                    toast.show()
                })
            })();
        </script>
    }
}
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Id)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.BorrowerName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.LenderName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Amount)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.IsSettled)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Id)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.BorrowerName)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.LenderName)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Amount)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.IsSettled)
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary me-1">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary me-1">Details</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
        </div>
    </div>
</div>
