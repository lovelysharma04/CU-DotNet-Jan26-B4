@{
    ViewData["Title"] = "Home Page";
}
<div class="container-fluid text-white text-center p-5"
     style="background: url('/image/cu.jpg');
            background-size:cover;
            background-position:center;">

    <h1>Chandigarh University Company Portal</h1>
    <p>Welcome to the official portal for students and employees</p>
    <button class="btn btn-primary btn-lg" id="toastBtn">Get Started</button>
</div>


<div class="position-fixed fixed-bottom end-0 p-3">
    <div id="liveToast" class="toast">
        <div class="toast-header">
            <strong class="me-auto ">CU Portal</strong>
            <button type="button" class="btn-close" data-bs-dismiss="toast"></button>
        </div>
        <div class="toast-body text-black">
            Welcome to Chandigarh University Portal!
        </div>
    </div>
</div>

<script>
    document.getElementById("toastBtn").onclick = function () {
        var toastElement = document.getElementById("liveToast");
        var toast = new bootstrap.Toast(toastElement);
        toast.show();
    };
</script>

<div class="container mt-5 p-1">
    <div class="row text-center">

        <div class="col-md-4 d-flex">
            <div class="card w-100 bg-white d-flex flex-column">
                <img src="~/image/student.jpg" class="card-img-top" alt="Students" style="height:200px; object-fit:cover;">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">Student Services</h5>
                    <p class="card-text">Check attendance, assignments, and exam schedules.</p>
                    <div class="mt-auto">
                        <a href="https://students.cuchd.in/" target="_blank" class="btn btn-danger">Login</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4 d-flex">
            <div class="card w-100 bg-white d-flex flex-column">
                <img src="~/image/course.jpg" class="card-img-top" alt="Courses" style="height:200px; object-fit:cover;">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">Courses</h5>
                    <p class="card-text">Access course materials and online learning resources.</p>
                    <div class="mt-auto">
                      <a href="https://lms.cuchd.in/login/index.php" target="_blank" class="btn btn-danger">Learn Now</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4 d-flex">
            <div class="card w-100 bg-white d-flex flex-column">
                <img src="~/image/support.jpg" class="card-img-top" alt="Support" style="height:200px; object-fit:cover;">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">Support</h5>
                    <p class="card-text">Contact the university helpdesk for assistance.</p>
                    <div class="mt-auto">
                     <a href="Contact" class="btn btn-danger">Contact</a>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>


