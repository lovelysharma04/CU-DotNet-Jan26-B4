
@{
    ViewData["Title"] = "About";
}

<div class="container mt-5">

    <!-- Page Title -->
    <div class="text-center bg-white mb-4">
        <h2 class="fw-bold">About Chandigarh University Portal</h2>
        <p class="text-muted">A digital platform designed to simplify academic and administrative services.</p>
    </div>

    <!-- Bootstrap Alert -->
    <div class="alert alert-secondary alert-dismissible fade show shadow-sm text-center" role="alert">
        <strong>Welcome!</strong> This portal provides students and staff with quick access to essential university services.
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>

    <!-- Features Section -->
    <div class="mt-5">
        <h4 class="mb-3 fw-semibold text-white">Portal Features</h4>

        <ul class="list-group shadow-sm">

            <li class="list-group-item d-flex justify-content-between align-items-center">
                Student Attendance Tracking
                <span class="badge bg-success">Active</span>
            </li>

            <li class="list-group-item d-flex justify-content-between align-items-center">
                Course Materials Access
                <span class="badge bg-primary">Available</span>
            </li>

            <li class="list-group-item d-flex justify-content-between align-items-center">
                Assignment Submission
                <span class="badge bg-warning text-dark">Online</span>
            </li>

            <li class="list-group-item d-flex justify-content-between align-items-center">
                University Announcements
                <span class="badge bg-info">Updates</span>
            </li>

            <li class="list-group-item d-flex justify-content-between align-items-center">
                Support and Helpdesk
                <span class="badge bg-danger">24/7</span>
            </li>

        </ul>
    </div>

</div>

