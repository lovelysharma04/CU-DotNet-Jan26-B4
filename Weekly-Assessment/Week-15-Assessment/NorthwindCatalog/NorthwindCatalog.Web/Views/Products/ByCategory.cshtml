@model List<NorthwindCatalog.Services.DTOs.ProductDto>

<h2>Products</h2>
<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">@item.ProductName</h5>
                    <p>Price: @item.UnitPrice.ToString("C")</p>
                    <p>Units In Stock: @item.UnitsInStock</p>
                    <p><strong>Inventory Value: @item.InventoryValue.ToString("C")</strong></p>
                </div>
            </div>
        </div>
    }
</div>