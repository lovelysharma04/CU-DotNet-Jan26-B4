<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - JAVLN</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>
<body>

    <header class="navbar">
        <a href="/" class="nav-brand">
            JAVLN<span class="brand-dot"></span>
        </a>

        <nav class="nav-links">
            <a href="#">LAPTOPS</a>
            <a href="#">MOBILE</a>
            <a href="#">COLLECTIONS</a>
            <a href="#">JOURNAL</a>
        </nav>

        <div class="nav-actions">

            <!-- Cart icon -->
            <a href="#" class="nav-icon-btn" title="Cart">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <path d="M6 2 3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" />
                    <line x1="3" y1="6" x2="21" y2="6" />
                    <path d="M16 10a4 4 0 01-8 0" />
                </svg>
                <span class="nav-badge">3</span>
            </a>

            <!-- ── PROFILE DROPDOWN (CSS-only checkbox trick) ── -->
            <div class="profile-wrap">
                <!-- Hidden checkbox drives open/close -->
                <input type="checkbox" id="profileToggle" class="profile-chk" />

                <!-- Label acts as the button -->
                <label for="profileToggle" class="nav-icon-btn profile-trigger" title="My Account">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" />
                        <circle cx="12" cy="7" r="4" />
                    </svg>
                </label>

                <!-- Click-away overlay — closes on click by unchecking -->
                <label for="profileToggle" class="profile-overlay"></label>

                <!-- The dropdown panel -->
                <div class="profile-dropdown">
                    <div class="pd-header">
                        <div class="pd-avatar">AS</div>
                        <div>
                            <p class="pd-name">Abhay Sharma</p>
                            <p class="pd-email">abhay@example.com</p>
                        </div>
                    </div>
                    <div class="pd-divider"></div>
                    <a href="/Address" class="pd-item @(ViewData["Title"]?.ToString() == "My Addresses" ? "pd-active" : "")">
                        <span class="pd-icon">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0118 0z" /><circle cx="12" cy="10" r="3" /></svg>
                        </span>
                        My Addresses
                    </a>
                    <a href="#" class="pd-item">
                        <span class="pd-icon">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2 3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" /><line x1="3" y1="6" x2="21" y2="6" /><path d="M16 10a4 4 0 01-8 0" /></svg>
                        </span>
                        My Orders
                    </a>
                    <a href="#" class="pd-item">
                        <span class="pd-icon">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3" /><path d="M19.07 4.93a10 10 0 010 14.14M4.93 4.93a10 10 0 000 14.14" /></svg>
                        </span>
                        Settings
                    </a>
                    <div class="pd-divider"></div>
                    <a href="#" class="pd-item pd-logout">
                        <span class="pd-icon">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>
                        </span>
                        Sign Out
                    </a>
                </div>
            </div>
            <!-- ── END PROFILE DROPDOWN ── -->

        </div>

        <button class="hamburger" onclick="document.querySelector('.nav-links').classList.toggle('open')">
            <span></span><span></span><span></span>
        </button>
    </header>

    <main>@RenderBody()</main>

    <footer class="footer">
        <div class="footer-inner">
            <div class="footer-brand">
                <div class="footer-logo">JAVLN<span class="brand-dot"></span></div>
                <p>Engineered for the modern professional who views their workspace as a sanctuary of focus and precision.</p>
            </div>
            <div class="footer-col">
                <h4>SHOP</h4>
                <a href="#">Laptops</a>
                <a href="#">Mobile</a>
                <a href="#">Collections</a>
                <a href="#">New Arrivals</a>
            </div>
            <div class="footer-col">
                <h4>COMPANY</h4>
                <a href="#">About</a>
                <a href="#">Journal</a>
                <a href="#">Careers</a>
                <a href="#">Contact</a>
            </div>
            <div class="footer-col footer-newsletter">
                <h4>NEWSLETTER</h4>
                <p>Early access to launches, drops, and exclusive offers for members.</p>
                <form class="nl-form" method="post">
                    <input type="email" placeholder="your@email.com" />
                    <button type="submit">&#8594;</button>
                </form>
            </div>
        </div>
        <div class="footer-bottom">
            <span>&copy; 2026 JAVLN. All rights reserved.</span>
            <div>
                <a href="#">Privacy Policy</a>
                <a href="#">Terms of Service</a>
                <a href="#">Shipping</a>
                <a href="#">Returns</a>
            </div>
        </div>
    </footer>

</body>
</html>
