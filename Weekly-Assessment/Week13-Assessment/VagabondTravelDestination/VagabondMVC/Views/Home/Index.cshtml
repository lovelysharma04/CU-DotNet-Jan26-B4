@{
    ViewData["Title"] = "Home";
}

<style>
    .hero {
        height: 100vh;
        background: url('/images/travel.jpg') no-repeat center center/cover;
        position: relative;
        color: white;
    }

    .overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
    }

    .hero-content {
        position: relative;
        z-index: 2;
        text-align: center;
        top: 50%;
        transform: translateY(-50%);
        animation: fadeIn 2s ease-in-out;
    }
      @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(-50%);
        }
    }

    .hero h1 {
        font-size: 60px;
        font-weight: bold;
        letter-spacing: 3px;
    }

    .hero p {
        font-size: 18px;
        margin-top: 15px;
        color: #ddd;
    }

    .btn-custom {
        margin-top: 25px;
        padding: 12px 30px;
        font-size: 18px;
        border-radius: 30px;
    }

    .divider {
        width: 80px;
        height: 3px;
        background: #ff4d6d;
        margin: 20px auto;
    }

    .explore-text {
        position: absolute;
        bottom: 30px;
        width: 100%;
        text-align: center;
        letter-spacing: 3px;
        font-size: 14px;
        color: #ccc;
    }
</style>

<div class="hero">
    <div class="overlay"></div>

    <div class="hero-content">
        
        <!-- Logo (optional) -->
        @* <img src="/images/logo.png" width="80" class="mb-3" /> *@

        <h1>VAGABOND</h1>

        <div class="divider"></div>

        <p>
            Welcome to Vagabond, your passport to <br />
            effortless and immersive travel planning!
        </p>

        <a href="/Travel/Index" class="btn btn-outline-light btn-lg btn-custom">
            Explore Now →
        </a>
    </div>

    <div class="explore-text">
        EXPLORE THE WORLD
    </div>
</div>
