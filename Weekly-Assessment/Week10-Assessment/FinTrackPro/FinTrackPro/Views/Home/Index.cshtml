@model FinTrackPro.Models.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-4 home-bg">
    <div class="row mb-4">
        <div class="col-12 text-center">
            <h1 class="display-5">FinTrack Pro</h1>
            <p class="text-muted">Quick overview of your accounts and recent activity</p>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h6 class="card-title">Total Accounts</h6>
                    <h3>@Model.TotalAccounts</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h6 class="card-title">Total Balance</h6>
                    <h3>@($"₹{Model.TotalBalance:N2}")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center border-success">
                <div class="card-body">
                    <h6 class="card-title">Total Credit</h6>
                    <h3 class="text-success">@($"₹{Model.TotalCredit:N2}")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center border-danger">
                <div class="card-body">
                    <h6 class="card-title">Total Debit</h6>
                    <h3 class="text-danger">@($"₹{Model.TotalDebit:N2}")</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    Recent Transactions
                </div>
                <div class="card-body p-0">
                    @if (Model.RecentTransactions != null && Model.RecentTransactions.Any())
                    {
                        <table class="table table-sm mb-0">
                            <thead>
                                <tr>
                                    <th>Account</th>
                                    <th>Description</th>
                                    <th>Amount</th>
                                    <th>Category</th>
                                    <th>Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var t in Model.RecentTransactions)
                                {
                                    <tr>
                                        <td>@t.Account?.AccountHolderName</td>
                                        <td>@t.Description</td>
                                        <td class="fw-bold" style="color:@(t.Category != null && t.Category.Equals("Credit", System.StringComparison.OrdinalIgnoreCase) ? "green" : t.Category != null && t.Category.Equals("Debit", System.StringComparison.OrdinalIgnoreCase) ? "red" : "inherit")">@($"₹{t.Amount:N2}")</td>
                                        <td>@t.Category</td>
                                        <td>@t.Date.ToShortDateString()</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="p-3">No recent transactions</div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header">Quick Actions</div>
                <div class="card-body">
                    <a class="btn btn-primary w-100 mb-2" href="/Accounts">Manage Accounts</a>
                    <a class="btn btn-success w-100 mb-2" href="/Transactions/Create">Add Transaction</a>
                    <a class="btn btn-secondary w-100" href="/Transactions">View All Transactions</a>
                </div>
            </div>
        </div>
    </div>

</div>
