@model FinTrackPro.Models.Transaction

@{
    ViewData["Title"] = "Create";
}

<div class="transaction-bg page-bg create-bg">
    <h2 class="mb-3">Add New Transaction</h2>
    <form asp-action="Create" class="row g-3">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

        <div class="col-md-6">
            <label asp-for="Description" class="form-label">Description <span class="text-muted">✎</span></label>
            <input asp-for="Description" class="form-control" placeholder="e.g., Salary, Grocery" />
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="col-md-3">
            <label asp-for="Amount" class="form-label">Amount <span class="symbol-small">₹</span></label>
            <div class="input-group">
                <span class="input-group-text">₹</span>
                <input asp-for="Amount" class="form-control fw-bold" placeholder="0.00" />
            </div>
            <span asp-validation-for="Amount" class="text-danger"></span>
        </div>

        <div class="col-md-3">
            <label asp-for="Category" class="form-label">Category</label>
            <select asp-for="Category" class="form-select" asp-items="ViewBag.CategoryList">
                <option value="">-- Select --</option>
            </select>
            <span asp-validation-for="Category" class="text-danger"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="Date" class="form-label">Date</label>
            <input asp-for="Date" class="form-control" type="date" />
            <span asp-validation-for="Date" class="text-danger"></span>
        </div>

        <div class="col-md-8">
            <label asp-for="AccountId" class="form-label">Account</label>
            <select asp-for="AccountId" class ="form-select" asp-items="ViewBag.AccountId"></select>
            <span asp-validation-for="AccountId" class="text-danger"></span>
        </div>

        <div class="col-12">
            <button type="submit" class="btn btn-success"> <span class="symbol-small">＋</span> Create Transaction</button>
            <a asp-action="Index" class="btn btn-secondary ms-2">Back to List</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
